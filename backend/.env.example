# LLM Provider 1: OpenAI Compatible
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o

# LLM Provider 2: Aliyun DashScope
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_API_KEY=sk-xxx
ALIYUN_MODEL=qwen-plus

# LLM Provider 3: Ollama Local
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# LLM Provider Priority (comma separated)
LLM_PROVIDER_PRIORITY=openai_compatible,aliyun,ollama

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./data/offerpilot.db
